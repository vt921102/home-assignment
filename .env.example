# ============================================================
# Flash Sale Backend — Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------
# JWT Keystore
# Generated by: ./scripts/gen-keystore.sh
# -----------------------------------------------
JWT_KEYSTORE_PASSWORD=changeit
JWT_KEY_ALIAS=jwt-signing

# -----------------------------------------------
# OTP Security
# Generate with: openssl rand -hex 32
# -----------------------------------------------
OTP_HASH_PEPPER=replace_with_random_64_hex_chars

# -----------------------------------------------
# Database (override defaults if needed)
# -----------------------------------------------
# DB_URL=jdbc:postgresql://postgres:5432/flashsale
# DB_USERNAME=app
# DB_PASSWORD=app_password

# -----------------------------------------------
# Redis (override defaults if needed)
# -----------------------------------------------
# REDIS_HOST=redis